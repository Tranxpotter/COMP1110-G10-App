{
  "name": "Expo React Native",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspaces/project-bare",
  "postCreateCommand": "npm install --force && npm install --global @expo/ngrok@^4.1.0",
  "forwardPorts": [8081, 19000, 19001, 19002, 19006],
  "portsAttributes": {
    "8081": {
      "label": "Metro Bundler"
    },
    "19000": {
      "label": "Expo DevTools"
    },
    "19001": {
      "label": "Expo DevTools WebSocket"
    },
    "19002": {
      "label": "Expo Tunnel"
    },
    "19006": {
      "label": "Expo Web"
    }
  },
  "containerEnv": {
    "EXPO_DEVTOOLS_LISTEN_ADDRESS": "0.0.0.0"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "expo.vscode-expo-tools"
      ]
    }
  }
}
